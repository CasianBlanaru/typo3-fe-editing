{
    "name": "pixelcoda/typo3-fe-editing",
    "description": "Production-ready TYPO3 frontend editing with inline editing, drag-and-drop, contextual records, headless support, accessibility and optional AI.",
    "keywords": [
        "typo3",
        "typo3-extension",
        "frontend-editing",
        "inline-editing",
        "drag-and-drop",
        "headless-cms",
        "accessibility",
        "ai"
    ],
    "license": "GPL-2.0-or-later",
    "type": "project",
    "authors": [
        {
            "name": "Casian Blanaru",
            "homepage": "https://pixelcoda.de"
        }
    ],
    "support": {
        "issues": "https://github.com/CasianBlanaru/pixelcoda-typo3-fe-editing/issues",
        "source": "https://github.com/CasianBlanaru/pixelcoda-typo3-fe-editing"
    },
    "config": {
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        },
        "platform": {
            "php": "8.2.0"
        },
        "sort-packages": true
    },
    "require": {
        "bk2k/bootstrap-package": "^15.0",
        "pixelcoda/fe-editor": "dev-master",
        "pixelcoda/fe-editor-sitepackage": "dev-master",
        "typo3/cms-backend": "^13.4",
        "typo3/cms-belog": "^13.4",
        "typo3/cms-beuser": "^13.4",
        "typo3/cms-core": "^13.4",
        "typo3/cms-dashboard": "^13.4",
        "typo3/cms-extbase": "^13.4",
        "typo3/cms-extensionmanager": "^13.4",
        "typo3/cms-felogin": "^13.4",
        "typo3/cms-filelist": "^13.4",
        "typo3/cms-fluid": "^13.4",
        "typo3/cms-fluid-styled-content": "^13.4",
        "typo3/cms-form": "^13.4",
        "typo3/cms-frontend": "^13.4",
        "typo3/cms-impexp": "^13.4",
        "typo3/cms-info": "^13.4",
        "typo3/cms-install": "^13.4",
        "typo3/cms-reactions": "^13.4",
        "typo3/cms-recycler": "^13.4",
        "typo3/cms-rte-ckeditor": "^13.4",
        "typo3/cms-seo": "^13.4",
        "typo3/cms-setup": "^13.4",
        "typo3/cms-sys-note": "^13.4",
        "typo3/cms-tstemplate": "^13.4",
        "typo3/cms-viewpage": "^13.4",
        "typo3/cms-webhooks": "^13.4"
    },
    "repositories": {
        "local": {
            "type": "path",
            "url": "packages/*"
        },
        "0": {
            "type": "path",
            "url": "./packages/*"
        }
    }
}
